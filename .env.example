TELEGRAM_BOT_TOKEN=your_bot_token_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Local dev: force long polling (do not set webhook)
# USE_POLLING=1

# Optional webhook secret (set the same on Railway). Telegram sends X-Telegram-Bot-Api-Secret-Token
# TELEGRAM_WEBHOOK_SECRET=random-long-string

# Only if you need to take webhook down so local getUpdates works (do NOT use on prod while Railway runs)
# DELETE_WEBHOOK_BEFORE_POLLING=1

# Railway sets RAILWAY_PUBLIC_DOMAIN and PORT; bot then uses webhook automatically.
